rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productos/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create, update: if signedIn() && request.auth.uid == reviewId;
        allow delete: if isAdmin() || (signedIn() && request.auth.uid == reviewId);
      }
    }

    match /pedidos/{orderId} {
      allow create: if true;
      allow read: if true;
      allow update: if isAdmin()
        || (
          resource.data.pago.metodoSeleccionado == 'mercadopago'
          && request.resource.data.status == 'en_proceso'
          && request.resource.data.pago.acreditado == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'pago', 'updatedAt'])
        );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if owns(userId) || isAdmin();
      allow create, update: if owns(userId) || isAdmin();
      allow delete: if isAdmin();

      match /favorites/{favoriteId} {
        allow read, create, update, delete: if owns(userId) || isAdmin();
      }

      match /pedidos/{orderId} {
        allow read: if owns(userId) || isAdmin();
        allow create, update, delete: if owns(userId) || isAdmin();
      }
    }

    match /visits/{visitId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
